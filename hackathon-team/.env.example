# ╔══════════════════════════════════════════════════════════════╗
# ║  AEGIS — Environment Configuration                          ║
# ║  Copy this to .env and fill in your credentials              ║
# ╚══════════════════════════════════════════════════════════════╝

# === LLM Provider ===
# Lightning AI proxies LLM calls natively via OpenClaw — no OpenAI/Anthropic keys needed.
# Set LLM_PROVIDER=lightning when running on Lightning AI Studios.
# Fall back to openai or anthropic for local dev if you have a key.
LLM_PROVIDER=lightning       # options: lightning, openai, anthropic

# === Lightning AI (fill from Profile -> Global Settings -> Keys) ===
LIGHTNING_GATEWAY_KEY=       # Gateway API key (from Profile -> Global Settings -> Keys)
OPENCLAW_URL=                # e.g. https://18789-YOUR_SUBDOMAIN.cloudspaces.litng.ai
LIGHTNING_API_KEY=           # Lightning platform key (optional)

# === Validia (fill at event) ===
VALIDIA_API_KEY=             # From event credentials — middleware runs in mock mode without this
VALIDIA_ENDPOINT=https://api.validia.ai/v1/scan

# === Fallback LLM keys (only needed if LLM_PROVIDER != lightning) ===
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# === Middleware Config ===
MIDDLEWARE_PORT=8080          # Port for Validia-gated webhook interceptor

# === App Config ===
MEMORY_DB_PATH=./memory/sessions.db
